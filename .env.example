# SecureGate public environment template
# Copy this file to `.env` for local development.

# -----------------------------------------------------------------------------
# Next.js application
# -----------------------------------------------------------------------------

# Public URL for the SecureGate web app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL used by the browser to talk to Supabase.
# For local Supabase CLI this is usually http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon key for the web app and CLI login flow.
# Get this from `supabase status` or your hosted Supabase project settings.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key

# Optional public API origin for generated snippets. Leave equal to NEXT_PUBLIC_APP_URL
# unless you expose SecureGate behind a separate API domain.
NEXT_PUBLIC_SECUREGATE_API_URL=http://localhost:3000

# Optional internal Supabase URL for the Next.js container/runtime.
# In Docker Compose this should point to the host machine or an internal Supabase service.
SUPABASE_INTERNAL_URL=http://host.docker.internal:54321

# -----------------------------------------------------------------------------
# Shared app / email settings
# -----------------------------------------------------------------------------

# Canonical app URL used by backend services when building links in emails.
APP_URL=http://localhost:3000

# From address for contact requests and security alert emails.
SECUREGATE_FROM_EMAIL=SecureGate <noreply@example.com>

# Destination inbox for dashboard contact requests.
CONTACT_EMAIL_TO=maintainer@example.com

# Optional Resend API key. Required only if you want email delivery.
RESEND_API_KEY=replace_with_resend_api_key

# -----------------------------------------------------------------------------
# Supabase Edge Functions
# -----------------------------------------------------------------------------

# Supabase project URL visible to Edge Functions.
SUPABASE_URL=http://127.0.0.1:54321

# Service role key used by Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key

# Anon key used by some Edge Functions when validating user sessions.
SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key

# 32+ character secret used for AES-GCM encryption of provider credentials.
ENCRYPTION_KEY=replace_with_a_32_character_minimum_secret

# -----------------------------------------------------------------------------
# Optional CLI overrides
# -----------------------------------------------------------------------------

# The CLI defaults to local development values, but you can override them here.
SECUREGATE_WEB_URL=http://localhost:3000
SECUREGATE_API_URL=http://localhost:3000/v1
SECUREGATE_SUPABASE_URL=http://127.0.0.1:54321
SECUREGATE_SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key
